{
  "name": "Payment",
  "type": "object",
  "properties": {
    "sale_id": {
      "type": "string",
      "description": "Reference to Sale entity"
    },
    "payment_date": {
      "type": "string",
      "format": "date",
      "description": "Date of payment"
    },
    "amount": {
      "type": "number",
      "description": "Payment amount"
    },
    "currency": {
      "type": "string",
      "default": "USD",
      "description": "Payment currency"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "Cash",
        "Installment"
      ],
      "description": "Method of payment"
    },
    "payment_type": {
      "type": "string",
      "enum": [
        "advanced_payment",
        "monthly",
        "scheduled_payment",
        "additional",
        "final"
      ],
      "description": "Type of payment"
    },
    "reference_number": {
      "type": "string",
      "description": "Transaction reference number"
    },
    "is_delayed": {
      "type": "boolean",
      "default": false,
      "description": "Whether payment was delayed"
    },
    "delay_days": {
      "type": "integer",
      "default": 0,
      "description": "Number of days delayed"
    },
    "notes": {
      "type": "string",
      "description": "Payment notes"
    }
  },
  "required": [
    "sale_id",
    "payment_date",
    "amount"
  ]
}