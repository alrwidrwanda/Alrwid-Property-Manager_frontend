{
  "name": "Client",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Client full name"
    },
    "contract_number": {
      "type": "string",
      "description": "Contract reference number"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "phone": {
      "type": "string",
      "description": "Primary phone number"
    },
    "address": {
      "type": "string",
      "description": "Residential address"
    },
    "nationality": {
      "type": "string",
      "description": "Nationality"
    },
    "identification_number": {
      "type": "string",
      "description": "ID/Passport number"
    },
    "id_picture_url": {
      "type": "string",
      "description": "URL to the uploaded ID or Passport picture"
    },
    "contract_document_url": {
      "type": "string",
      "description": "URL to the uploaded signed contract document"
    },
    "preferred_payment_method": {
      "type": "string",
      "enum": [
        "Cash",
        "Installment"
      ],
      "default": "Cash",
      "description": "Preferred payment method"
    },
    "preferred_currency": {
      "type": "string",
      "default": "USD",
      "description": "Preferred currency"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the client"
    }
  },
  "required": [
    "full_name",
    "phone"
  ]
}